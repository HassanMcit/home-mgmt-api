generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Family {
  id                 String   @id @default(cuid())
  name               String
  plan               String   @default("free") // "free" or "premium"
  subscriptionStatus String   @default("active") // "active", "suspended"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users        User[]
  transactions Transaction[]
  budgets      Budget[]
  savings      Saving[]
  bills        Bill[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("family_admin") // "super_admin", "family_admin", "member"
  avatar    String?
  familyId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)

  transactions        Transaction[] @relation("UserTransactions")
  createdTransactions Transaction[] @relation("CreatedTransactions")
  budgets             Budget[]
  savings             Saving[]
  bills               Bill[]
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  familyId    String?
  amount      Float
  type        String // "income" | "expense"
  category    String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String?

  user    User    @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)
  creator User?   @relation("CreatedTransactions", fields: [createdById], references: [id], onDelete: SetNull)
  family  Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  familyId  String?
  category  String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model Saving {
  id            String    @id @default(cuid())
  userId        String
  familyId      String?
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  color         String    @default("#10b981")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model Bill {
  id          String   @id @default(cuid())
  userId      String
  familyId    String?
  name        String
  amount      Float
  dueDate     DateTime
  isPaid      Boolean  @default(false)
  isRecurring Boolean  @default(false)
  category    String   @default("other")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model RegistrationRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
