generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("member") // "admin" | "member"
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[] @relation("UserTransactions")
  createdTransactions Transaction[] @relation("CreatedTransactions")
  budgets      Budget[]
  savings      Saving[]
  bills        Bill[]
  reminders    Reminder[]
  accounts     Account[]
  splitBillsPaidBy     SplitBill[]         @relation("SplitBillsPaidBy")
  splitParticipations  SplitParticipant[]  @relation("SplitParticipations")
}

model RegistrationRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String   // "income" | "expense"
  category    String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String?
  accountId   String?
  
  user User @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)
  creator User? @relation("CreatedTransactions", fields: [createdById], references: [id], onDelete: SetNull)
  account     Account? @relation("AccountTransactions", fields: [accountId], references: [id], onDelete: SetNull)
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  category  String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model Saving {
  id        String   @id @default(cuid())
  userId    String
  name      String
  targetAmount Float
  currentAmount Float @default(0)
  deadline  DateTime?
  color     String   @default("#10b981")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bill {
  id          String   @id @default(cuid())
  userId      String
  name        String
  amount      Float
  dueDate     DateTime
  isPaid      Boolean  @default(false)
  isRecurring Boolean  @default(false)
  category    String   @default("other")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id              String    @id @default(cuid())
  userId          String
  title           String
  description     String?
  isCompleted     Boolean   @default(false)
  reminderAt      DateTime? // optional scheduled reminder time
  emailSent       Boolean   @default(false)
  priority        String    @default("medium") // "low" | "medium" | "high"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Account {
  id               String   @id @default(cuid())
  userId           String
  name             String
  type             String   // "bank" | "cash"
  iban             String?
  accountNum       String?
  balance          Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  alias            String?
  subType          String?  // "current" | "deposit"
  depositAmount    Float?
  interestRate     Float?
  interestDay      Int?
  lastInterestPaid DateTime?
  denominations    Json?

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[] @relation("AccountTransactions")
}

// ─── شيل معايا — Bill Splitting ──────────────────────────────────────────────

/// A bill-splitting session created by a user.
model SplitBill {
  id          String   @id @default(cuid())
  /// The user who initiated and paid the bill
  paidById    String
  /// Human-friendly title, e.g. "خروجة القهوة"
  title       String
  /// Full bill amount in EGP
  totalAmount Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paidBy       User               @relation("SplitBillsPaidBy", fields: [paidById], references: [id], onDelete: Cascade)
  participants SplitParticipant[]

  @@index([paidById])
}

/// One row per person in a split session.
model SplitParticipant {
  id              String    @id @default(cuid())
  splitBillId     String
  /// Free-text name for guests not registered in the system
  participantName String
  /// Optional: linked to a registered User account
  participantId   String?
  /// Exact amount this participant owes
  owedAmount      Float
  /// Has this participant settled their share?
  isPaid          Boolean   @default(false)
  /// When they settled (null = not yet paid)
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  splitBill   SplitBill @relation(fields: [splitBillId], references: [id], onDelete: Cascade)
  participant User?     @relation("SplitParticipations", fields: [participantId], references: [id], onDelete: SetNull)

  @@index([splitBillId])
  @@index([participantId])
}

